# ── Kalshi API ────────────────────────────────────────────────────────
KALSHI_API_KEY_ID=a8ceabc1-4a50-4234-8281-c1b4f913fe22
KALSHI_PRIVATE_KEY_PATH=./keys/prod_private_key.pem

KALSHI_API_BASE_URL=https://trading-api.kalshi.com
# ==============================================
# Database
# ==============================================
# SQLite (default — no setup required):
DATABASE_URL=sqlite:///kalshi_trader.db

# PostgreSQL (optional):
# DATABASE_URL=postgresql://user:password@localhost:5432/kalshi_trader

# ==============================================
# Strategy parameters
# ==============================================
ENTRY_THRESHOLD=0.52
STOP_LOSS=0.46
MAX_SPREAD=0.08
POSITION_SIZE=1         # start small while testing
PAPER_TRADE=True # Seconds before restarting a crashed worker
LOG_LEVEL=INFO

