# ── Required ──────────────────────────────────────────────────────────
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=/home/ubuntu/Kalshi98/keys/prod_private_key.pem

# ── Optional (defaults shown) ─────────────────────────────────────────
