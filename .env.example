# ==============================================
# Kalshi API credentials (RSA key auth)
# ==============================================
KALSHI_API_KEY_ID=your-key-id-here
KALSHI_PRIVATE_KEY_PATH=C:\path\to\your\private_key.pem

# ==============================================
# Database
# ==============================================
# SQLite (default — no setup required):
DATABASE_URL=

# PostgreSQL (optional):
# DATABASE_URL=postgresql://user:password@localhost:5432/kalshi_trader

# ==============================================
# Strategy parameters
# ==============================================
ENTRY_THRESHOLD=0.50      # Crossover trigger (dollar units, 0.0–1.0)
STOP_LOSS=0.48            # Hard stop loss level
MAX_SPREAD=0.10           # Skip market if ask - bid > this
MIN_LIQUIDITY_DOLLARS=5.0 # Min orderbook depth to enter
POSITION_SIZE=1           # Contracts per trade

# ==============================================
# System
# ==============================================
MAX_MARKETS=10            # Max simultaneous market workers
WORKER_RESTART_DELAY=5.0  # Seconds before restarting a crashed worker
LOG_LEVEL=INFO

# ==============================================
# Safety
# ==============================================
PAPER_TRADE=true          # Set to false for live trading — use with caution
